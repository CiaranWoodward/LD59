[node name="DrugMan" parent="RandomEncounters" unique_id=1340358284 instance=ExtResource("2_dfmul")]
title = "The World We Live In"
encounter_text = "A creature rushes at you in a crazed state.

[i]\"GIVE THEM TO ME. I KNOW YOU HAVE THEM.\"[/i]"
encounter_text_sane = "You've seen this before. You've [i]been[/i] this before."
encounter_text_insane = "You don't know what it wants."
choicea_text = "Give it a blue shroom"
choicea_card_required = "Blue Shroom"
choiceb_text = "It snatches a blue shroom"
