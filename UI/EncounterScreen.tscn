[node name="BlindfoldMan" parent="RandomEncounters" unique_id=1113694585 instance=ExtResource("2_dfmul")]
title = "A Sight not Seen"
encounter_text = "A strange creature, wearing a blindfold and a massive grin.

[i]\"Hello friend, do you find yourself getting distracted by the inane?\"[/i]

It presents you with a spare blindfold."
choicea_text = "Put the Blindfold On"
choicea_card = ExtResource("3_f6xpe")
skip_text = "Refuse"

[node name="MapMan" parent="RandomEncounters" unique_id=358179260 instance=ExtResource("2_dfmul")]
title = "The Way Ahead"
encounter_text = "A hooded being emerges from the trees.

[i]\"Child looks lost. Creature knows what lies ahead.\"[/i]

It holds out a map and a knife. It seems that knowledge requires sacrifice."
choicea_text = "Offer a blood sacrifice"
choicea_card = ExtResource("7_ak22r")
choicea_stat_delta = -2

[node name="AxeMan" parent="RandomEncounters" unique_id=1948968966 instance=ExtResource("2_dfmul")]
title = "The Woodcutter"
encounter_text = "A creature passes by struggling to carry the wood on its back.

It trips scattering wood logs the ground. You see the glint of an axe amongst the wood."
encounter_text_sane = "You reckon you're quicker than this clumsy oaf. You could take the axe and dispose of this creature."
encounter_text_insane = "Such a nice woodcutter surely needs this axe."
choicea_text = "Steal the axe"
choicea_card = ExtResource("10_mq3g3")
choicea_sanity = 1
skip_text = "Watch from a distance"

[node name="BowMan" parent="RandomEncounters" unique_id=87727534 instance=ExtResource("2_dfmul")]
title = "The Hunter"
encounter_text = "A small creature passes by struggling to carry the meat on its back.

