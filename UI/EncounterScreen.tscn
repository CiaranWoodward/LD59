[node name="JourneyStart" parent="SpecificEncounters" unique_id=1367821565 instance=ExtResource("2_dfmul")]
title = "Hope"
encounter_text = "You see the unmistakable smoke signal from the Bazaar in the distance.

After so much time, is it really open for business once more?

Its a long journey - what do you take with you?"
choicea_text = "My Bow"
choicea_card = ExtResource("4_f6xpe")
choiceb_text = "My Axe"
choiceb_card = ExtResource("3_nqibp")
skip_text = ""

[node name="DayBreak" parent="SpecificEncounters" unique_id=429885594 instance=ExtResource("2_dfmul")]
title = "Morning has Broken"
encounter_text = "A fresh morning,

But reality reaches ever closer."
encounter_text_sane = "Need something to take the edge off..."
encounter_text_insane = "Time to press on"
skip_text = "On with the day"
skip_stat = 1
skip_stat_delta = -1

[node name="FirstStep" parent="SpecificEncounters" unique_id=433325646 instance=ExtResource("2_dfmul")]
title = "First Steps"
encounter_text = "You're getting closer. The Bazaar's signals are still distant, but you're making progress.

Perhaps there are others heading the same way.

You recall a distant memory of how to communicate."
choicea_text = "I Can Signal Them"
choicea_card = ExtResource("16_lr62w")
skip_text = ""

[node name="GameComplete" parent="SpecificEncounters" unique_id=667859661 instance=ExtResource("2_dfmul")]
title = "Hope"
encounter_text = "The Bazaar stands in front of you, one of the few constructions left in this world."
encounter_text_sane = "Crumbling and filthy, half of the spaced out inhabitants appear to be looking straight through you.

The other half look like they want to eat you.

Thanks for Playing!"
encounter_text_insane = "A beautiful paradise, bustling with life. It really is back! A utopia, rich with opportunity and prosperity, the last bastion of society!

Thank you for playing!"
skip_text = "Restart"
game_complete_screen = true

[node name="ActiveEncounter" type="Node" parent="." unique_id=200731604]
