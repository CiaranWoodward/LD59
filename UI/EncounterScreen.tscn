title = "A Sight not Seen"
encounter_text = "A strange creature, wearing a blindfold and a massive grin.

[i]\"Hello friend, do you find yourself getting distracted by the inane?\"[/i]

It presents you with a spare blindfold."
choicea_text = "Put the Blindfold On"
choicea_card = ExtResource("3_f6xpe")
